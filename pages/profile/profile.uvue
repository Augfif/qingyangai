<script setup lang="ts">
import { computed } from 'vue'
import { username, isLoggedIn, logout, initAuth } from '@/stores/user'

// ========== TYPE DEFINITIONS ==========

type UserStat = {
	value: string
	label: string
}

type HealthMetric = {
	emoji: string
	label: string
	value: string
	status: 'good' | 'normal' | 'warning'
	statusText: string
}

type HealthReport = {
	updateDate: string
	metrics: HealthMetric[]
	summary: string
}

type SubscriptionPerk = {
	emoji: string
	text: string
}

type Subscription = {
	perks: SubscriptionPerk[]
}

type ServiceItem = {
	emoji: string
	title: string
	subtitle: string
	badge?: string
}

type SettingItem = {
	emoji: string
	title: string
}

// ========== MOCK DATA ==========

const user = {
	avatar: '🧑‍💼',
	name: '张同学',
	level: '翡翠会员',
	levelEmoji: '💎',
}

const userStats: UserStat[] = [
	{ value: '47', label: '累计打卡' },
	{ value: '92%', label: '达标率' },
	{ value: '3', label: '连续周' },
]

const report: HealthReport = {
	updateDate: '2026年5月10日',
	metrics: [
		{ emoji: '⚖️', label: 'BMI', value: '22.1', status: 'good', statusText: '标准' },
		{ emoji: '🫁', label: '体脂率', value: '18.5%', status: 'good', statusText: '优秀' },
		{ emoji: '🍎', label: '营养分', value: '87', status: 'good', statusText: '良好' },
		{ emoji: '😴', label: '睡眠', value: '7.2h', status: 'normal', statusText: '正常' },
		{ emoji: '💓', label: '静息心率', value: '68', status: 'good', statusText: '健康' },
		{ emoji: '🧠', label: '专注指数', value: '中', status: 'warning', statusText: '待优化' },
	],
	summary: '您的整体营养状况良好，BMI与体脂率处于健康区间。建议增加Omega-3脂肪酸摄入以辅助提升专注力，已为您调整下周膳食方案。',
}

const subscription: Subscription = {
	perks: [
		{ emoji: '♾️', text: '无限次 AI 膳食方案生成' },
		{ emoji: '🚫', text: '全平台无广告纯净体验' },
		{ emoji: '👨‍⚕️', text: '三甲医师团队方案审核' },
		{ emoji: '📊', text: '月度深度营养分析报告' },
		{ emoji: '🎯', text: 'ADHD & 慢病专属方案' },
		{ emoji: '💬', text: '专属营养师在线咨询' },
	],
}

const services: ServiceItem[] = [
	{ emoji: '🍃', title: '慢病专属方案', subtitle: '高血压 · 糖尿病 · 痛风 定制膳食', badge: '热门' },
	{ emoji: '👨‍⚕️', title: '医师轻咨询', subtitle: '30分钟线上营养咨询 · ¥49/次' },
	{ emoji: '📄', title: '营养报告下载', subtitle: 'PDF详细报告 · 可分享给医生' },
	{ emoji: '🔬', title: '食物不耐受检测', subtitle: '预约线下检测 · 精准排除过敏原' },
]

const settings: SettingItem[] = [
	{ emoji: '🎯', title: '饮食偏好设置' },
	{ emoji: '🔗', title: '健康数据同步' },
	{ emoji: '📖', title: '膳食百科' },
	{ emoji: '❓', title: '帮助与反馈' },
	{ emoji: 'ℹ️', title: '关于我们' },
]
// ========== AUTH STATE ==========
initAuth()

const displayName = computed((): string => {
	if (isLoggedIn.value && username.value !== "") {
		return username.value
	}
	return '未登录'
})

function handleLogout() {
	logout()
	uni.showToast({ title: '已退出登录', icon: 'none' })
	setTimeout(function () {
		uni.reLaunch({ url: '/pages/welcome/welcome' })
	}, 500)
}

function handleGoLogin() {
	uni.navigateTo({ url: '/pages/login/login' })
}

</script>

