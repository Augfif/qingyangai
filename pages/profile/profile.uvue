					</view>
				</view>
			</view>
	
		<!-- ===== Health Report Card ===== -->
		<view class="report-card">
			<view class="report-card__header">
				<text class="report-card__title">📋 健康报告摘要</text>
				<view class="report-card__verify">
					<text class="report-card__verify-emoji">✅</text>
					<text class="report-card__verify-text">协和营养科 审核</text>
				</view>
			</view>
			<text class="report-card__date">更新于 {{ report.updateDate }}</text>

			<!-- Metrics Grid -->
			<view class="report-card__metrics">
				<view
					v-for="metric in report.metrics"
					:key="metric.label"
					class="report-card__metric"
				>
					<text class="report-card__metric-emoji">{{ metric.emoji }}</text>
					<text class="report-card__metric-value">{{ metric.value }}</text>
