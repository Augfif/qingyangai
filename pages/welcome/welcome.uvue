	letter-spacing: 1px;
	text-align: center;
	margin-bottom: 12px;
}
.subtitle {
	font-size: 16px;
	color: #64748b;
	letter-spacing: 1px;
	text-align: center;
}

/* ===== Feature Pills ===== */
.feature-row {
	flex-direction: row;
	justify-content: center;
	flex-wrap: wrap;
	margin-top: 50px;
	margin-bottom: 40px;
}
