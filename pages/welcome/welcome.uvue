<template>
	<view class="page">
		<view class="status-spacer" />

		<view class="item" :class="{ 'item--show': visible[0] }">
			<text class="brand-name">轻养AI</text>
		</view>

		<view class="item" :class="{ 'item--show': visible[1] }">
			<image class="hero-image" src="/static/salad-bowl.svg" mode="aspectFit" />
		</view>

		<view class="item" :class="{ 'item--show': visible[2] }">
			<text class="main-title">AI 一键规划三餐</text>
			<text class="subtitle">智能定制，轻卡美味</text>
			<view class="feature-row">
				<view class="feature-pill"><text class="feature-pill__text">AI对话</text></view>
				<view class="feature-pill"><text class="feature-pill__text">膳食规划</text></view>
				<view class="feature-pill"><text class="feature-pill__text">健康追踪</text></view>
				<view class="feature-pill"><text class="feature-pill__text">拍照识食</text></view>
			</view>
		</view>

		<view class="item button-area" :class="{ 'item--show': visible[3] }">
			<view class="btn btn--primary" @tap="handleEnter">
				<text class="btn__text btn__text--primary">立即开始</text>
			</view>
			<view class="btn btn--secondary" @tap="handleEnter">
				<text class="btn__text btn__text--secondary">登录 / 注册</text>
			</view>
			<view class="home-indicator" />
		</view>
	</view>
</template>

<script setup lang="ts">
import { ref, onMounted } from 'vue'

// Each group controlled independently — browser only handles ONE transition at a time
const visible = ref<boolean[]>([false, false, false, false])

const DURATION = 550  // ms per animation
const GAP = 120       // ms pause between groups

onMounted(() => {
	const start = 80
	const step = DURATION + GAP

	setTimeout(() => { visible.value[0] = true }, start)
	setTimeout(() => { visible.value[1] = true }, start + step)
	setTimeout(() => { visible.value[2] = true }, start + step * 2)
	setTimeout(() => { visible.value[3] = true }, start + step * 3)
})

const handleEnter = () => {
	uni.setStorageSync('hasLaunched', 'true')
	uni.reLaunch({ url: '/pages/index/index' })
}
</script>

<style scoped>
