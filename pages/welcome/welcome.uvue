	font-size: 13px;
	font-weight: 500;
	color: #10b981;
}

/* ===== Button Area ===== */
.button-area {
	width: 100%;
	margin-top: auto;
	margin-bottom: 40px;
}
.btn {
	width: 100%;
	height: 54px;
	border-radius: 27px;
	align-items: center;
	justify-content: center;
	margin-bottom: 16px;
}
.btn--primary {
	background-color: #10b981;
	box-shadow: 0 4px 12px rgba(16, 185, 129, 0.20);
}
.btn--secondary {
	background-color: transparent;
	border: 1px solid #10b981;
}
.btn__text {
	font-size: 18px;
	font-weight: 500;
}
