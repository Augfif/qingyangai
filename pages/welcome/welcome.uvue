.page {
	flex: 1;
	flex-direction: column;
	align-items: center;
	background: linear-gradient(180deg, #f7fdfa 0%, #edf8f3 100%);
	padding: 0 32px;
}
.status-spacer {
	height: 60px;
}

/* ===== Flex Spacer (replaces margin-top: auto) ===== */
.flex-spacer {
	flex: 1;
}

/* ===== Animation Item ===== */
.item {
	flex-direction: column;
	align-items: center;
	opacity: 0;
	transform: translateY(50px);
	transition-property: all;
	transition-duration: 0.55s;
	transition-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.item-1 { transition-delay: 0s; }
.item-2 { transition-delay: 0.12s; }
.item-3 { transition-delay: 0.24s; }
.item-4 { transition-delay: 0.36s; }
.item--show {
	opacity: 1;
	transform: translateY(0);
}

/* ===== Brand Name ===== */
.brand-name {
	font-size: 40px;
	font-weight: bold;
	color: #10b981;
	letter-spacing: 1px;
	margin-bottom: 40px;
}

/* ===== Hero Image ===== */
.hero-image {
	width: 130px;
	height: 130px;
	margin-bottom: 30px;
}

/* ===== Title & Subtitle ===== */
.main-title {
	font-size: 32px;
	font-weight: 600;
	color: #1e293b;
	letter-spacing: 1px;
	text-align: center;
	margin-bottom: 12px;
}
.subtitle {
	font-size: 16px;
	color: #64748b;
	letter-spacing: 1px;
	text-align: center;
}

/* ===== Feature Pills ===== */
.feature-row {
	flex-direction: row;
	justify-content: center;
	flex-wrap: wrap;
	margin-top: 50px;
	margin-bottom: 40px;
}
.feature-pill {
	padding: 8px 16px;
	border-radius: 12px;
	background-color: rgba(16, 185, 129, 0.08);
	margin: 5px;
}
.feature-pill__text {
	font-size: 13px;
	font-weight: 500;
	color: #10b981;
}

/* ===== Button Area ===== */
.button-area {
	width: 100%;
	margin-bottom: 40px;
}
.btn {
	width: 100%;
	height: 54px;
	border-radius: 27px;
	align-items: center;
	justify-content: center;
	margin-bottom: 16px;
}
.btn--primary {
	background-color: #10b981;
	box-shadow: 0 4px 12px rgba(16, 185, 129, 0.20);
}
.btn--secondary {
	background-color: transparent;
	border: 1px solid #10b981;
}
