<template>
	<view class="page">
		<view class="status-spacer" />

		<view class="item item-1" :class="{ 'item--show': isReady }">
			<text class="brand-name">轻养AI</text>
		</view>

		<view class="item item-2" :class="{ 'item--show': isReady }">
			<image class="hero-image" src="/static/salad-bowl.svg" mode="aspectFit" />
		</view>

		<view class="item item-3" :class="{ 'item--show': isReady }">
			<text class="main-title">AI 一键规划三餐</text>
			<text class="subtitle">智能定制，轻卡美味</text>
			<view class="feature-row">
				<view class="feature-pill"><text class="feature-pill__text">AI对话</text></view>
				<view class="feature-pill"><text class="feature-pill__text">膳食规划</text></view>
				<view class="feature-pill"><text class="feature-pill__text">健康追踪</text></view>
				<view class="feature-pill"><text class="feature-pill__text">拍照识食</text></view>
			</view>
		</view>

		<view class="flex-spacer" />

		<view class="item button-area item-4" :class="{ 'item--show': isReady }">
			<view class="btn btn--primary" @tap="handleEnter">
				<text class="btn__text btn__text--primary">立即开始</text>
			</view>
			<view class="btn btn--secondary" @tap="handleLogin">
				<text class="btn__text btn__text--secondary">登录 / 注册</text>
			</view>
			<view class="home-indicator" />
		</view>
	</view>
</template>

<script setup lang="ts">
import { ref } from 'vue'
import { onReady, onLoad } from '@dcloudio/uni-app'

const isReady = ref<boolean>(false)
let hasAnimated = false

onLoad((_) => {
	const hasLaunched = uni.getStorageSync('hasLaunched')
	if (hasLaunched === 'true') {
		uni.redirectTo({ url: '/pages/index/index' })
	}
})

onReady(() => {
	if (hasAnimated) return
	setTimeout(() => {
		isReady.value = true
		hasAnimated = true
	}, 80)
})

const handleEnter = () => {
	uni.setStorageSync('hasLaunched', 'true')
	uni.reLaunch({ url: '/pages/index/index' })
}

const handleLogin = () => {
	uni.navigateTo({ url: '/pages/login/login' })
}
</script>

<style scoped>
